# Copy this file to .env and set the Blender 5.2+ executable for your platform.

BLENDER_BIN="/path/to/blender"

ASSET_ROOT="blender/assets"
# Default to in-place generation so local Blender can serve the source asset root.
# Set BUILD_ROOT=".build/blender_remote_asset" for an isolated copy build.
BUILD_ROOT="blender/assets"

HTTP_BIND="127.0.0.1"
HTTP_PORT="8000"
